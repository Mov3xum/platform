{
  "name": "platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace @platform/web dev",
    "build": "yarn workspace @platform/web build",
    "start": "yarn workspace @platform/web start",
    "lint": "yarn workspace @platform/web lint",
    "typecheck": "yarn workspace @platform/web typecheck",
    "verify:pb-baseline": "node backend/pocketbase-schema/scripts/verify-baseline.mjs",
    "test": "node --import ./scripts/register-test-hooks.mjs --experimental-strip-types --test packages/shared/src/*.test.ts apps/web/src/lib/*.test.ts apps/web/src/lib/users/*.test.ts apps/web/src/lib/ai/*.test.ts"
  },
  "packageManager": "yarn@1.22.22",
  "resolutions": {
    "@types/node": "20.19.39"
  }
}
