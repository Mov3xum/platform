# PocketBase configuration
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8080

# Initialt app-admin-lösen (hampus@movexum.se) — sätts som secret i Coolify.
# Migration 13 läser detta vid första containerstart och seedar app-användaren.
# Tom = hoppar över seed. Lämna tom efter första lyckade login.
APP_ADMIN_INITIAL_PASSWORD=

# Encryption (optional, for PocketBase)
POCKETBASE_ENCRYPTION_KEY=

# Feature flags (modules)
NEXT_PUBLIC_MODULE_STARTUPS_ENABLED=true
NEXT_PUBLIC_MODULE_PROGRAMS_ENABLED=false
NEXT_PUBLIC_MODULE_COACHING_ENABLED=false
NEXT_PUBLIC_MODULE_ACTIVITIES_ENABLED=false
NEXT_PUBLIC_MODULE_DOCUMENTS_ENABLED=false
NEXT_PUBLIC_MODULE_FUNDING_ENABLED=false
NEXT_PUBLIC_MODULE_SUSTAINABILITY_ENABLED=false
NEXT_PUBLIC_MODULE_INTERNATIONALIZATION_ENABLED=false
NEXT_PUBLIC_MODULE_MENTORS_ENABLED=false
NEXT_PUBLIC_MODULE_APPLICATIONS_ENABLED=false
NEXT_PUBLIC_MODULE_REPORTING_ENABLED=false

# Node environment
NODE_ENV=development
