# Lokal dev använder osuffixad URL. I Coolify sätts istället MOVEXUM_ENV
# (staging|production) + de _STAGING/_PRODUCTION-suffixade paren — se .env.example
# i repo-roten för deployment-exempel. Default = staging om MOVEXUM_ENV är osatt.
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8080

# Resend e-post API (https://resend.com — skaffa nyckel under API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Bas-URL för appen (används i verifieringslänkar i mail)
NEXT_PUBLIC_APP_URL=https://din-domän.se

# Hemlig nyckel för HMAC-signering av verifieringstoken (minst 32 slumpmässiga tecken)
VERIFICATION_SECRET=CHANGE_ME_TO_AT_LEAST_32_RANDOM_CHARACTERS

# PocketBase-superuser (hanteras i PocketBase admin-UI /_/)
# Krävs för att markera användare som verified efter e-postverifiering
POCKETBASE_SUPERUSER_EMAIL=
POCKETBASE_SUPERUSER_PASSWORD=
